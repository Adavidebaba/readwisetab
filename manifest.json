{
  "manifest_version": 3,
  "name": "Readwise New Tab Quotes",
  "version": "1.1.0",
  "description": "Mostra una citazione casuale da Readwise ogni volta che apri un nuovo tab.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://readwise.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
